---
import SectionLayout from "@/layouts/SectionLayout.astro";
import { personalInfo } from "@/data/config";
---

<SectionLayout id="contact" class="py-16">
  <div class="max-w-2xl mx-auto px-4">
    <h2
      class="text-4xl font-bold text-center mb-6 text-white"
      data-aos="fade-down"
      data-aos-offset="100"
      data-aos-duration="900"
      data-aos-once="true"
    >
      Conectemos
    </h2>

    <p
      class="text-center text-neutral-300 text-lg mb-10"
      data-aos="fade-up"
      data-aos-offset="100"
      data-aos-delay="200"
      data-aos-duration="900"
      data-aos-once="true"
    >
      Si tienes un proyecto o una idea en mente, me encantaría hablar al
      respecto.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div
        class="group p-6 border border-neutral-700 rounded-lg bg-neutral-900/40 hover:bg-neutral-900/80 hover:border-fuchsia-500 transition-all"
        data-aos="fade-right"
        data-aos-offset="100"
        data-aos-delay="300"
        data-aos-duration="900"
        data-aos-once="true"
      >
        <div class="flex items-start gap-4">
          <div class="text-fuchsia-500 text-2xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-white mb-2">Email</h3>
            <p class="text-neutral-400 text-sm mb-3">{personalInfo.email}</p>
            <button
              id="copy-button"
              class="text-fuchsia-500 hover:text-fuchsia-400 text-sm font-medium transition"
            >
              Copiar email
            </button>
          </div>
        </div>
      </div>

      <div
        class="group p-6 border border-neutral-700 rounded-lg bg-neutral-900/40 hover:bg-neutral-900/80 hover:border-fuchsia-500 transition-all"
        data-aos="fade-left"
        data-aos-offset="100"
        data-aos-delay="400"
        data-aos-duration="900"
        data-aos-once="true"
      >
        <div class="flex items-start gap-4">
          <div class="text-fuchsia-500 text-2xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="font-semibold text-white mb-3">Redes Sociales</h3>
            <div class="flex gap-3">
              <a
                href={personalInfo.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-neutral-400 hover:text-fuchsia-500 transition"
                title="GitHub"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                  ></path>
                </svg>
              </a>
              <a
                href={personalInfo.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-neutral-400 hover:text-fuchsia-500 transition"
                title="LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.474-2.235-1.668-2.235-.909 0-1.451.612-1.688 1.204-.087.211-.109.505-.109.799v5.801h-3.554s.047-9.411 0-10.39h3.554v1.471c.469-.723 1.305-1.748 3.168-1.748 2.314 0 4.051 1.513 4.051 4.766v5.901zM5.337 8.855c-1.144 0-1.915-.758-1.915-1.708 0-.955.771-1.71 1.958-1.71 1.187 0 1.914.755 1.939 1.71 0 .95-.752 1.708-1.982 1.708zm1.582 11.597H3.635V9.062h3.284v11.39zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="text-center"
      data-aos="zoom-in"
      data-aos-offset="100"
      data-aos-delay="500"
      data-aos-duration="900"
      data-aos-once="true"
    >
      <a
        href={`mailto:${personalInfo.email}`}
        class="inline-flex items-center gap-2 px-8 py-3 bg-fuchsia-600 hover:bg-fuchsia-500 text-white font-semibold rounded-lg transition-colors"
      >
        <span>Enviarme un email</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <script define:vars={{ personalInfo }}>
    const button = document.querySelector("#copy-button");
    if (button) {
      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(personalInfo.email);
          const original = button.textContent;
          button.textContent = "¡Copiado!";
          setTimeout(() => (button.textContent = original), 1800);
        } catch (err) {
          console.error("Error al copiar:", err);
        }
      });
    }
  </script>
</SectionLayout>
