---
type CarouselImage = string | { src: string; alt?: string };

const { images = [] } = Astro.props as { images?: CarouselImage[] };
---

<div class="carousel" aria-label="Galeria de imagenes">
  {images.map((img, i) => {
    const src = typeof img === "string" ? img : img.src;
    const alt = typeof img === "string" ? `Imagen ${i + 1}` : (img.alt ?? `Imagen ${i + 1}`);

    return (
      <article class="slide">
        <img src={src} loading="lazy" decoding="async" alt={alt} />
      </article>
    );
  })}
</div>


<style>
  .carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    gap: 1rem;

    overflow-x: auto;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;

    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;

    padding: 0 1rem 1rem;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel {
    scrollbar-width: none;
  }

  .slide {
    scroll-snap-align: center;
    scroll-snap-stop: always;
    border-radius: 1rem;
    overflow: hidden;
    background: #111;
  }

  .slide img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .carousel {
      grid-auto-columns: 40%;
    }

    .slide img {
      height: 280px;
    }
  }

  @media (min-width: 1024px) {
    .carousel {
      grid-auto-columns: 28%;
    }
  }
</style>

