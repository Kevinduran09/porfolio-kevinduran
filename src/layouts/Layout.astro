---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SiteBackground from "@/components/SiteBackground.astro";

interface LayoutProps {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props as LayoutProps;

const site = Astro.site ?? new URL("https://kevoduran.com/");
const canonicalUrl = canonical
  ? new URL(canonical, site).toString()
  : new URL(Astro.url.pathname, site).toString();
const ogUrl = canonicalUrl;
const ogImageUrl = ogImage
  ? new URL(ogImage, site).toString()
  : new URL("/og.jpg", site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="keywords" content="Kevin Duran" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="google-site-verification"
      content="4z9ec7fNrR2liXYGHBxIbmyx9FYd9w2wD6UrW6NM8i0"
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kevin Duran | Portafolio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <ClientRouter />
  </head>
  <body class="text-white min-h-screen min-h-[100svh] w-full min-w-full bg-slate-950">
    <SiteBackground />
    <div class="relative z-10 min-h-screen min-h-[100svh]">
      <main class="min-h-screen min-h-[100svh]">
        <slot />
      </main>
    </div>
    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      AOS.init();
    </script>
  </body>
</html>
